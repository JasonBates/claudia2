{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claudia2",
  "version": "0.3.9",
  "identifier": "com.jasonbates.claudia2",
  "build": {
    "beforeDevCommand": "npm run bundle:bridge && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claudia2",
        "width": 800,
        "height": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#002b36",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "cli": {
      "description": "Claudia2 - Claude Terminal Interface with Memory",
      "args": [
        {
          "name": "directory",
          "index": 1,
          "takesValue": true,
          "required": false
        },
        {
          "name": "resume",
          "short": "r",
          "takesValue": true,
          "required": false
        }
      ]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcyMTNDMDNCQjQyODRFRkQKUldUOVRpaTBPOEFUY3V5TTBaek05bjNFMEZza1p0a3F6TE52RUNUaFpPQnVZREk4NEJtbTJ6YUoK",
      "endpoints": [
        "https://github.com/JasonBates/claudia2/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../sdk-bridge-v2.mjs",
      "../context/engine.mjs",
      "../context/context-map.mjs",
      "../context/zep-loop.bundle.mjs"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
